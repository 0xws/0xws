---
import { Content as README } from "../README.md";

import Navbar from "./components/Navbar.astro";
import Mascot from "./components/Mascot.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>0xws</title>
  </head>

  <body class="flex flex-col items-center text-sm md:text-lg text-indigo-300">
    <div class="mt-16 flex">
      <div
        class="max-w-xs md:max-w-3xl flex flex-col items-center md:items-stretch"
      >
        <Navbar />
        <div
          class="max-w-4xl mb-4 pt-12 pb-8 px-8 md:p-12 bg-[#1e1b4b] prose prose-sm md:prose-lg prose-slate prose-invert min-h-64"
        >
          <slot />
        </div>
      </div>
      <div class="mt-12 max-w-xs p-8 flex flex-col items-center gap-6">
        <Mascot />
        <div class="flex flex-col gap-4">
          <README />
        </div>
      </div>
    </div>
    <div class="text-sm">
      Background: <a href="https://heropatterns.com/">Hero Patterns</a> | 3D Model:
      <a href="https://skfb.ly/6Tnso">Lexyc16</a> | Inspired by <a
        href="https://djnn.sh">djnn.sh</a
      > ❤️
    </div>
  </body>
</html>

<style is:global>
  :root {
    @apply bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-[#030117] to-[#070424];
    font-family: "JetBrains Mono", monospace;
    overflow-x: hidden;
    background-color: theme(colors.indigo.900);
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    &::before {
      color: theme(colors.indigo.500);
      font-weight: 900;
    }
  }

  h1 {
    @apply text-3xl pb-1 border-b border-indigo-500;

    &::before {
      content: "# ";
    }
  }

  h2 {
    @apply text-2xl;

    &::before {
      content: "## ";
    }
  }

  h3 {
    @apply text-xl;

    &::before {
      content: "### ";
    }
  }

  h4 {
    @apply text-lg;

    &::before {
      content: "#### ";
    }
  }

  h5 {
    @apply text-sm;

    &::before {
      content: "##### ";
    }
  }

  h6 {
    @apply text-xs;

    &::before {
      content: "###### ";
    }
  }

  a {
    @apply underline;

    &:hover {
      @apply text-indigo-500;
    }
  }
</style>

<style>
  body {
    @apply w-full min-h-screen;

    background-image: url("/bg.svg");
    background-size: 1200px;
  }
</style>
