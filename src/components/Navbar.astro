---
import Search from "./Search.astro";

const links = [
  { name: "λ", href: "/" },
  { name: "📓 Blog", href: "/blog" },
  { name: "😺 Friends", href: "/friends" },
  { name: "🐙 Github", href: "https://github.com/0xws" },
];
---

<nav
  class="flex justify-center items-center text-xs lg:text-lg w-full py-4 text-lg"
>
  <div class="flex justify-between items-center w-full max-w-4xl">
    <ul class="flex justify-center items-center gap-3 ml-4 font-bold">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="px-2 py-1 rounded-sm hover:bg-[#1e1b4b]">
              {l.name}
            </a>
          </li>
        ))
      }
    </ul>
    <Search />
  </div>
</nav>

<style>
  nav a {
    @apply no-underline;
  }
</style>
